@using Microsoft.AspNetCore.Http
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] | Seval Koca</title>
    
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500&family=Jost:wght@300;400;500&display=swap" rel="stylesheet">
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>

    <div class="top-bar">
        <span>2500₺ ve üzeri alışverişlerinizde kargo bedava ♦ Üye Ol ve İlk Siparişine Özel %10 İndirim Kazan</span>
    </div>

  <header class="navbar">
        <div class="nav-left dropdown">
            <a href="#" class="dropbtn">Tüm Ürünler <i class="fa-solid fa-chevron-down" style="font-size: 10px;"></i></a>
            <div class="dropdown-content">
                <a href="/Home/Kategori?id=1">Üst Giyim</a>
                <a href="/Home/Kategori?id=2">Alt Giyim</a>
                <a href="/Home/Kategori?id=3">Aksesuar</a>
            </div>
        </div>
        <div class="logo">
            <a href="/">SEVAL KOCA</a>
        </div>
        <div class="nav-right">
            @if (Context.Session.GetString("GirisYapildi") == "Evet")
            {
                @if (Context.Session.GetString("KullaniciRol") == "Admin")
                {
                    <a asp-controller="Home" asp-action="UrunYonetimi" style="margin-right: 10px; font-weight: bold; color: #000; text-decoration: none;">
                        <i class="fa-solid fa-user-gear"></i> Panel
                    </a>
                }
                else
                {
                    <span style="font-weight: 400; color: #555; font-size: 14px;">
                        <i class="fa-solid fa-user"></i> Hoş Geldin, @Context.Session.GetString("KullaniciAd")
                    </span>
                }
                <a asp-controller="Home" asp-action="Logout" style="color: #dc3545; font-weight: bold; text-decoration: none;">
                    <i class="fa-solid fa-right-from-bracket"></i> Çıkış
                </a>
            }
            else
            {
                <a asp-controller="Home" asp-action="Login" style="font-weight: 500; color: #333; text-decoration: none;">
                    <i class="fa-solid fa-user"></i> Giriş Yap
                </a>
            }

            <!-- ARAMA: Tıklanınca açılan arama kutusu -->
            <a href="javascript:void(0);" onclick="aramaKutusuAc()" title="Ara">
                <i class="fa-solid fa-magnifying-glass"></i>
            </a>

                @{
                    // Hafızadaki metni al, eğer boş değilse yıldızlardan böl ve kaç parça olduğuna bak
                    string anlikSepet = Context.Session.GetString("Sepetim") ?? "";
                    int urunSayisi = string.IsNullOrEmpty(anlikSepet) ? 0 : anlikSepet.Split('*', StringSplitOptions.RemoveEmptyEntries).Length;
                }
                <a href="javascript:void(0);" onclick="sepetiAc()" style="cursor: pointer; text-decoration: none;">
                    <i class="fa-solid fa-bag-shopping"></i> <span class="cart-count">@urunSayisi</span>
                </a>
        </div>
    </header>

    <!-- ARAMA ÇUBUĞU (Varsayılan gizli, ikon tıklanınca açılır) -->
    <div id="aramaBarı" style="display: none; background: #f9f9f9; padding: 15px 40px; border-bottom: 1px solid #eee; transition: all 0.3s ease;">
        <form action="/Home/Ara" method="get" style="display: flex; align-items: center; max-width: 600px; margin: 0 auto; gap: 10px;">
            <input type="text" name="q" placeholder="Ürün ara..." required
                   style="flex: 1; padding: 12px 16px; border: 1px solid #ddd; border-radius: 4px; font-size: 1rem; font-family: 'Jost', sans-serif; outline: none;" />
            <button type="submit"
                    style="padding: 12px 24px; background: #000; color: #fff; border: none; border-radius: 4px; cursor: pointer; font-family: 'Jost', sans-serif; font-weight: 500; letter-spacing: 0.5px; transition: background 0.3s;">
                <i class="fa-solid fa-magnifying-glass"></i> Ara
            </button>
            <button type="button" onclick="aramaKutusuKapat()"
                    style="padding: 12px; background: none; border: none; cursor: pointer; font-size: 1.2rem; color: #999;">&times;</button>
        </form>
    </div>

    <main>
        @RenderBody()
    </main>

    <!-- ==========================================
         ZENGİN FOOTER
         ========================================== -->
    <footer class="site-footer">
        <div class="container">
            <div class="row justify-content-around text-center text-md-start">
                <!-- Sütun 1: Kategoriler -->
                <div class="col-md-4 mb-4 text-center">
                    <h3>Kategoriler</h3>
                    <ul class="footer-links">
                        <a href="/Home/Kategori?id=1">Üst Giyim</a><br>
                        <a href="/Home/Kategori?id=2">Alt Giyim</a><br>
                        <a href="/Home/Kategori?id=3">Aksesuar</a><br>
                        <a href="/Home/Kategori">Tüm Ürünler</a><br>
                    </ul>
                </div>
                <!-- Sütun 2: Hakkımızda -->
                <div class="col-md-4 mb-4 text-center">
                    <h3>Hakkımızda</h3>
                    <p class="footer-about-text">
                        Bir dikiş makinesiyle başlayan tutku, bugün anneden kıza geçen bir mirasla Seval Koca markasına dönüştü. El emeğini modern bir vizyonla harmanlayarak İstanbul ve Ankara'da hazır koleksiyonlar ve kişiye özel tasarımlar sunuyoruz. Bizim için moda sadece görünüş değil, kadının kendi hikâyesini anlattığı estetik bir ifadedir.
                    </p>
                </div>
                <!-- Sütun 3: İletişim -->
                <div class="col-md-4 mb-4 text-center">
                    <h3>İletişim</h3>
                    <ul class="footer-links">
                        <i class="fa-solid fa-location-dot" style="margin-right: 6px;"></i> İstanbul, Türkiye<br>
                        <i class="fa-solid fa-phone" style="margin-right: 6px;"></i> +90 555 123 4567<br>
                        <i class="fa-solid fa-envelope" style="margin-right: 6px;"></i> info@sevalkoca.com<br>
                    </ul>
                    <div class="footer-social mt-3 d-flex justify-content-center">
                        <a href="#"><i class="fa-brands fa-instagram"></i></a>
                        <a href="#"><i class="fa-brands fa-facebook"></i></a>
                        <a href="#"><i class="fa-brands fa-twitter"></i></a>
                        <a href="#"><i class="fa-brands fa-pinterest"></i></a>
                    </div>
                </div>
            </div>
            <div class="row mt-4">
                <div class="col-12">
                    <div class="footer-bottom d-flex flex-column flex-md-row justify-content-between align-items-center">
                        <span class="mb-2 mb-md-0">Şartlar ve Koşullar | Gizlilik Politikası | Erişilebilirlik</span>
                        <span>© 2025 Tüm Hakları Saklıdır. Created by Yüksek Yazılım</span>
                    </div>
                </div>
            </div>
        </div>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <script src="~/js/app.js"></script>

    <!-- sepet paneli -->
   <div id="sepetPaneli" style="position: fixed; top: 0; right: -400px; width: 350px; height: 100vh; background: #fff; box-shadow: -5px 0 25px rgba(0,0,0,0.05); padding: 30px 20px; transition: right 0.4s ease; z-index: 9999; display: flex; flex-direction: column; font-family: 'Jost', sans-serif; box-sizing: border-box;">
    
    <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #eaeaea; padding-bottom: 15px; margin-bottom: 20px;">
        <h2 style="font-family: 'Cinzel', serif; margin: 0; font-size: 1.4rem; letter-spacing: 1px; color: #000;">SEPETİM</h2>
        <button onclick="document.getElementById('sepetPaneli').style.right='-400px'" style="background: none; border: none; font-size: 1.8rem; cursor: pointer; color: #999;">&times;</button>
    </div>

    <div style="flex-grow: 1; overflow-y: auto;">
        @{
            string sepetMetni = Context.Session.GetString("Sepetim") ?? "";
            string[] urunler = sepetMetni.Split('*', StringSplitOptions.RemoveEmptyEntries);
            decimal toplamFiyat = 0;
        }

        @if(urunler.Length == 0)
        {
            <p style="text-align: center; color: #888; margin-top: 50px;">Sepetiniz şu an boş.</p>
        }
        else
        {
            for(int i = 0; i < urunler.Length; i++)
            {
                var detay = urunler[i].Split('|');
                toplamFiyat += Convert.ToDecimal(detay[1]);

                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; padding-bottom: 15px; border-bottom: 1px solid #f9f9f9;">
                    <div>
                        <h4 style="margin: 0; font-weight: 500; font-size: 1.1rem; color: #000;">@detay[0]</h4>
                        <p style="margin: 3px 0; color: #777; font-size: 0.9rem;">Beden: @detay[3]</p>
                        <p style="margin: 5px 0 0; font-weight: 500; color: #000;">₺@detay[1]</p>
                    </div>
                    
                    <a asp-controller="Home" asp-action="SepettenSil" asp-route-id="@i" style="color: #dc3545; font-size: 1.2rem; text-decoration: none; padding: 5px;" title="Sepetten Çıkar">
                        <i class="fa-solid fa-trash-can"></i>
                    </a>
                </div>
            }
        }
    </div>

    <div style="border-top: 1px solid #eaeaea; padding-top: 20px; margin-top: auto;">
        <div style="display: flex; justify-content: space-between; font-weight: 500; font-size: 1.2rem; margin-bottom: 20px; color: #000;">
            <span>TOPLAM</span>
            <span>₺@toplamFiyat</span>
        </div>

        <!-- SEPETİ ONAYLA butonu artık Checkout sayfasına yönlendiriyor -->
        <button onclick="window.location.href='/Home/SatinAl'" onmouseover="this.style.background='#333'" onmouseout="this.style.background='#000'" style="width: 100%; padding: 14px; background: #000; color: #fff; border: none; cursor: pointer; font-weight: 500; letter-spacing: 1px; transition: 0.3s; margin-bottom: 10px;">
            SEPETİ ONAYLA
        </button>

        <button onclick="document.getElementById('sepetPaneli').style.right='-400px'" style="width: 100%; padding: 14px; background: #fff; color: #000; border: 1px solid #000; cursor: pointer; font-weight: 500; letter-spacing: 1px; transition: 0.3s;">
            ALIŞVERİŞE DÖN
        </button>
    </div>
</div>

<script>
    function sepetiAc() { document.getElementById("sepetPaneli").style.right = "0"; }

    // Arama kutusu aç/kapat fonksiyonları
    function aramaKutusuAc() {
        var bar = document.getElementById("aramaBarı");
        bar.style.display = "block";
        bar.querySelector("input").focus();
    }
    function aramaKutusuKapat() {
        document.getElementById("aramaBarı").style.display = "none";
    }
</script>
</body>
</html>