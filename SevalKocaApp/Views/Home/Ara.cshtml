@model List<SevalKocaApp.Models.Urun>
@{
    ViewData["Title"] = "Arama Sonuçları";
}

<main class="category-page-container">
    
    <div class="category-header">
        <h1 class="category-title">
            @if (!string.IsNullOrEmpty(ViewBag.AramaTerimi as string))
            {
                <span>"@ViewBag.AramaTerimi" için arama sonuçları</span>
            }
            else
            {
                <span>Arama Sonuçları</span>
            }
        </h1>
        <div style="color: #888; font-size: 14px;">
            @Model.Count ürün bulundu
        </div>
    </div>

    <div class="products-grid">
    
        @foreach (var urun in Model)
        {
            <a asp-controller="Home" asp-action="UrunDetay" asp-route-id="@urun.UrunID" class="product-card">
                <img src="~/@urun.GorselURL" alt="@urun.UrunAdi">
                <h3>@urun.UrunAdi</h3>
                <p class="price">₺@urun.Fiyat</p>
            </a>
        }

        @if (Model.Count == 0)
        {
            <div style="text-align: center; padding: 80px 0; width: 100%;">
                <i class="fa-solid fa-magnifying-glass" style="font-size: 3rem; color: #ddd; margin-bottom: 20px; display: block;"></i>
                <p style="color: #888; font-size: 1.1rem; margin-bottom: 10px;">Aramanızla eşleşen ürün bulunamadı.</p>
                <p style="color: #aaa; font-size: 0.9rem;">Farklı anahtar kelimeler deneyebilirsiniz.</p>
                <a href="/" style="display: inline-block; margin-top: 20px; padding: 12px 30px; background: #000; color: #fff; text-decoration: none; border-radius: 4px; font-weight: 500; letter-spacing: 0.5px;">
                    Ana Sayfaya Dön
                </a>
            </div>
        }

    </div>
        
</main>
