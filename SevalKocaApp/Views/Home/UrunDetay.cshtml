@model SevalKocaApp.Models.Urun
@{
    // Sekme başlığını dinamik olarak ürünün adı yapıyoruz
    ViewData["Title"] = Model.UrunAdi;
}

<div class="product-detail-container">
    
    <!-- Yön Bulma (Breadcrumb) Çubuğu -->
    <div class="breadcrumb">
         <a href="~/">Ana Sayfa</a> / <a href="~/Home/Kategori">Üst Giyim</a> / <span>@Model.UrunAdi</span>
    </div>

          <div class="product-gallery">
               <div class="main-image">
                    <img src="~/@Model.GorselURL" alt="@Model.UrunAdi">
               </div>
               <div class="thumbnail-list">
                    <img src="~/@Model.GorselURL" class="active" alt="Önden Görünüm">
                    <img src="~/assets/ceket-arka.jpg" alt="Arkadan Görünüm">
                    <img src="~/assets/ceket-detay.jpg" alt="Kumaş Detayı">
               </div>
          </div>

         <!-- Sağ Taraf: Ürün Bilgileri ve Satın Alma -->
         <div class="product-info">
              <h1 class="product-title">@Model.UrunAdi</h1>
              <p class="product-price">₺@Model.Fiyat</p>
              
              <div class="product-description">
     Özel krokodil dokulu, yüksek kaliteli suni deriden üretilmiş, kısa kesim iddialı tasarım ceket. Hem gündüz şıklığına hem de gece davetlerine mükemmel uyum sağlar.
</div>

<form asp-controller="Home" asp-action="SepeteEkle" method="post">
    
    <input type="hidden" name="urunId" value="@Model.UrunID" />
    
    <input type="hidden" name="secilenBeden" id="gizliBeden" value="34" />

    <div class="size-selector" style="margin: 20px 0;">
         <span>Beden Seçin:</span>
         <button type="button" class="size-btn" onclick="document.getElementById('gizliBeden').value = '34'">34</button>
         <button type="button" class="size-btn" onclick="document.getElementById('gizliBeden').value = '36'">36</button>
         <button type="button" class="size-btn" onclick="document.getElementById('gizliBeden').value = '38'">38</button>
         <button type="button" class="size-btn" onclick="document.getElementById('gizliBeden').value = '40'">40</button>
    </div>

    <button type="submit" class="btn-add-to-cart">SEPETE EKLE</button>

</form>
<div class="product-details-accordion">
     <details>
         <summary>Ürün Özellikleri ve Kumaş</summary>
         <p>Materyal: %100 Poliüretan. Astar: %100 Polyester. Sadece kuru temizleme yapınız.</p>
     </details>
     <details>
         <summary>Teslimat ve İade Bilgisi</summary>
         <p>Siparişleriniz 1-3 iş günü içerisinde kargoya teslim edilmektedir. Etiketi koparılmamış ve kullanılmamış ürünleri 14 gün içerisinde ücretsiz iade edebilirsiniz.</p>
     </details>
</div>