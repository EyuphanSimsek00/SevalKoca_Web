@model List<SevalKocaApp.Models.Urun>
@{
    // Sayfa başlığını ViewBag'den dinamik olarak alıyoruz
    ViewData["Title"] = ViewBag.KategoriAdi ?? "Tüm Ürünler";
}

<main class="category-page-container">
    
    <div class="category-header">
        <h1 class="category-title">@(ViewBag.KategoriAdi ?? "TÜM ÜRÜNLER")</h1>
        <div class="category-filters">
            <!-- Sıralama Formu -->
            <form method="get" action="/Home/Kategori" class="d-inline-block">
                @if (ViewBag.SeciliKategoriID != null)
                {
                    <input type="hidden" name="id" value="@ViewBag.SeciliKategoriID" />
                }
                <select name="siralama" onchange="this.form.submit()" class="form-select form-select-sm" style="width: auto; display: inline-block; cursor: pointer;">
                    <option value="">Sıralama Seçiniz</option>
                    <option value="FiyatArtan" selected="@(ViewBag.SeciliSiralama == "FiyatArtan" ? "selected" : null)">Fiyat (Düşükten Yükseğe)</option>
                    <option value="FiyatAzalan" selected="@(ViewBag.SeciliSiralama == "FiyatAzalan" ? "selected" : null)">Fiyat (Yüksekten Düşüğe)</option>
                    <option value="IsimAZ" selected="@(ViewBag.SeciliSiralama == "IsimAZ" ? "selected" : null)">İsim (A-Z)</option>
                </select>
            </form>
            </div>
        </div>
    </div>

    <div class="products-grid">
    
        @foreach (var urun in Model)
        {
            <a asp-controller="Home" asp-action="UrunDetay" asp-route-id="@urun.UrunID" class="product-card">
                <img src="~/@urun.GorselURL" alt="@urun.UrunAdi">
                <h3>@urun.UrunAdi</h3>
                <p class="price">₺@urun.Fiyat</p>
            </a>
        }

        @if (Model.Count == 0)
        {
            <p style="text-align: center; color: #888; padding: 60px 0; font-size: 1.1rem; width: 100%;">
                Bu kategoride henüz ürün bulunmamaktadır.
            </p>
        }

    </div>
        
</main>